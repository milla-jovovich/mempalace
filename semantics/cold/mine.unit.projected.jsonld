      "DwnProtocol": "https://schema.fleet-to-force.dev/dwn#Protocol",
      "ObservationStream": "https://schema.fleet-to-force.dev/observation#Stream",
      "AssemblyArtifact": "https://schema.fleet-to-force.dev/assembly#Artifact",
      "authority": {
        "@id": "https://schema.fleet-to-force.dev/core#authority",
        "@type": "@id"
      },
      "protocol": {
        "@id": "https://schema.fleet-to-force.dev/core#protocol",
        "@type": "@id"
      },
      "permissionPolicy": {
        "@id": "https://schema.fleet-to-force.dev/core#permissionPolicy",
