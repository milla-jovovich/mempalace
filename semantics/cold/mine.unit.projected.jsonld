      },
      "bindsTo": {
        "@id": "https://schema.fleet-to-force.dev/core#bindsTo",
        "@type": "@id"
      },
      "realizedBy": {
        "@id": "https://schema.fleet-to-force.dev/core#realizedBy",
        "@type": "@id"
      },
      "emitsArtifact": {
        "@id": "https://schema.fleet-to-force.dev/core#emitsArtifact",
        "@type": "@id"
      },
      "observedBy": {
        "@id": "https://schema.fleet-to-force.dev/core#observedBy",
