{
  "source": {
    "package": "mempalace",
    "command": "mempalace",
    "hidden_dir": ".mempalace",
    "module_entry": "mempalace.mcp_server",
    "repo_url": "https://github.com/MemPalace/mempalace",
    "collections": {
      "drawers": "mempalace_drawers",
      "compressed": "mempalace_compressed",
      "closets": "mempalace_closets"
    }
  },
  "targets": [
    {
      "target": {
        "id": "memorymesh",
        "display_name": "MemoryMesh",
        "repo_url": "https://github.com/your-org/memorymesh"
      },
      "interpreter_policy": {
        "fallback_command": "python"
      }
    },
    {
      "target": {
        "id": "nexusmemory",
        "display_name": "NexusMemory",
        "repo_url": "https://github.com/your-org/nexusmemory"
      },
      "overrides": {
        "plugin_display_name": "Nexus Memory"
      },
      "interpreter_policy": {
        "fallback_command": "python"
      }
    }
  ]
}
